# iClawd 环境变量配置示例
# 将此文件复制为 .env 并填写对应值：
#   cp env.example .env

# 服务端口（默认 3000）
PORT=3000

# 数据库连接字符串（MySQL / TiDB）
# 如果不填，配置将存储在内存中（重启后丢失）
# 格式: mysql://user:password@host:port/database
DATABASE_URL=

# JWT 密钥（用于会话签名，建议修改为随机字符串）
JWT_SECRET=iclawd-local-secret-change-me

# ===== Manus 平台变量（本地运行时留空即可）=====
VITE_APP_TITLE=iClawd
VITE_APP_ID=
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
OWNER_OPEN_ID=
OWNER_NAME=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=
VITE_APP_LOGO=
